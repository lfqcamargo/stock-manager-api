// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat = "cjs"
  engineType = "client"
}

datasource db {
  provider = "postgresql"
}

model Email {
  id          String      @id @default(uuid())
  to          String
  subject     String
  body        String
  from        String?
  status      EmailStatus @default(pending)
  observation String?
  retryCount  Int         @default(0) @map("retry_count")
  createdAt   DateTime    @default(now()) @map("created_at")
  sentAt      DateTime?   @map("sent_at")

  @@map("emails")
}

model TempCompany {
  id             String    @id @default(uuid())
  companyName    String    @map("company_name")
  companyCnpj    String    @unique @map("company_cnpj")
  userName       String    @map("user_name")
  userEmail      String    @unique @map("user_email")
  userPassword   String    @map("user_password")
  token          String    @unique
  expirationDate DateTime  @map("expiration_date")

  @@map("temp_companies")
}

model TempUser {
  id             String    @id @default(uuid())
  name           String
  email          String    @unique
  password       String
  role           UserRole
  token          String    @unique
  expirationDate DateTime  @map("expiration_date")
  companyId      String    @map("company_id")

  @@map("temp_users")
}

model TempPasswordToken {
  id             String    @id @default(uuid())
  token          String    @unique
  expirationDate DateTime  @map("expiration_date")

  companyId      String    @map("company_id")
  company        Company   @relation(fields: [companyId], references: [id])

  userId         String    @map("user_id")
  user           User      @relation(fields: [userId], references: [id])

  @@map("temp_password_tokens")
}

model Company {
  id        String   @id @default(uuid())
  name      String
  cnpj      String   @unique
  photoUrl  String?  @map("photo_url")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  TempPasswordTokens TempPasswordToken[]
  users              User[]

  groups             Group[]
  materials          Material[]
  locations          Location[]
  subLocations       SubLocation[]
  rows               Row[]
  shelfs             Shelf[]
  positions          Position[]
  addressings        Addressing[]
  movementTypes      MovementType[]
  movements          Movement[]

  @@map("companies")
}

model User {
  id         String    @id @default(uuid())
  name       String
  email      String    @unique
  password   String
  role       UserRole
  active     Boolean
  photoUrl   String?   @map("photo_url")

  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt @map("updated_at")
  lastLogin  DateTime? @map("last_login")

  companyId  String    @map("company_id")
  company    Company   @relation(fields: [companyId], references: [id])

  tempPasswordTokens TempPasswordToken[]
  @@map("users")
}


model Group {
  id          String     @id @default(uuid())
  code        String
  name        String
  description String?
  active      Boolean
  photoUrl    String?    @map("photo_url")

  companyId   String     @map("company_id")

  company     Company    @relation(fields: [companyId], references: [id])
  material    Material[]

  @@map("groups")
}

model Material {
  id          String       @id @default(uuid())
  code        String
  name        String
  description String?
  active      Boolean
  photoUrl    String?      @map("photo_url")
  createdAt   DateTime     @default(now()) @map("created_at")

  companyId   String       @map("company_id")
  groupId     String       @map("group_id")

  unit        UnitMeasure
  company     Company      @relation(fields: [companyId], references: [id])
  group       Group        @relation(fields: [groupId], references: [id])
  addressings Addressing[]

  @@unique([companyId, code])
  @@map("materials")
}

model Location {
  id          String   @id @default(uuid())
  code        String
  name        String
  description String?

  companyId   String   @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id])

  subLocations SubLocation[]
  addressings  Addressing[]

  @@unique([companyId, code])
  @@map("locations")
}

model SubLocation {
  id          String   @id @default(uuid())
  code        String
  name        String
  description String?

  companyId   String   @map("company_id")
  locationId  String   @map("location_id")

  company     Company  @relation(fields: [companyId], references: [id])
  location    Location @relation(fields: [locationId], references: [id])

  addressings Addressing[]

  @@unique([companyId, code])
  @@map("sub_locations")
}

model Row {
  id          String   @id @default(uuid())
  code        String
  name        String
  description String?

  companyId   String   @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id])

  addressings Addressing[]

  @@unique([companyId, code])
  @@map("rows")
}

model Shelf {
  id          String   @id @default(uuid())
  code        String
  name        String
  description String?

  companyId   String   @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id])

  addressings Addressing[]

  @@unique([companyId, code])
  @@map("shelfs")
}

model Position {
  id          String   @id @default(uuid())
  code        String
  name        String
  description String?

  companyId   String   @map("company_id")
  company     Company  @relation(fields: [companyId], references: [id])

  addressings Addressing[]

  @@unique([companyId, code])
  @@map("positions")
}

model Addressing {
  id            String   @id @default(uuid())
  amount        Float    @default(0)
  active        Boolean
  createdAt     DateTime @default(now()) @map("created_at")

  companyId     String   @map("company_id")
  locationId    String   @map("location_id")
  subLocationId String   @map("sub_location_id")
  rowId         String   @map("row_id")
  shelfId       String   @map("shelf_id")
  positionId    String   @map("position_id")
  materialId    String?  @map("material_id")

  company       Company     @relation(fields: [companyId], references: [id])
  location      Location    @relation(fields: [locationId], references: [id])
  subLocation   SubLocation @relation(fields: [subLocationId], references: [id])
  row           Row         @relation(fields: [rowId], references: [id])
  shelf         Shelf       @relation(fields: [shelfId], references: [id])
  position      Position    @relation(fields: [positionId], references: [id])
  material      Material?   @relation(fields: [materialId], references: [id])

  @@map("addressings")
}


model MovementType {
  id          String            @id @default(uuid())
  name        String
  direction   MovementDirection

  companyId   String            @map("company_id")
  company     Company           @relation(fields: [companyId], references: [id])

  @@unique([companyId, name])
  @@map("movement_types")
}

model Movement {
  id              String   @id @default(uuid())
  quantity        Float
  date            DateTime
  observation     String?
  createdAt       DateTime @default(now()) @map("created_at")

  // Desnormalizado — sem FK para preservar histórico
  companyId       String   @map("company_id")
  addressingId    String   @map("addressing_id")
  movementTypeId  String   @map("movement_type_id")
  userId          String   @map("user_id")

  company         Company  @relation(fields: [companyId], references: [id])

  @@map("movements")
}

enum UnitMeasure {
  UN
  KG
  G
  MG
  TON
  L
  ML
  M
  CM
  MM
  M2
  M3
  CX
  PC
  PCT
  FD
  BDJ
  RL
  SC
  LT
  GAL
  JAR
  TBL
  KIT
}

enum MovementDirection {
  IN
  OUT
}

enum UserRole {
  ADMIN
  MANAGER
  EMPLOYEE
}

enum EmailStatus {
  pending
  sent
  failed
}
